  /* Pre line (for row-by-row skills reveal) */
  .pre-line { display: block; }

  /* Typing cursor */
  .type-cursor {
    color: var(--available);
    animation: cur-blink 0.65s step-end infinite;
    margin-left: 1px;
  }
  .type-cursor--done {
    animation: none;
    opacity: 0;
    transition: opacity 0.4s;
  }
  @keyframes cur-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* Copy email */
  .copy-email {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--link);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: color 0.15s;
    line-height: 1.4;
    vertical-align: middle;
  }
  .copy-email::before { content: '['; }
  .copy-email::after  { content: ']'; }

  .copy-email:hover {
    color: var(--text-bright);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .copy-email.copied {
    color: var(--available);
  }

  /* Responsive */
  @media (max-width: 760px) {
    .skills-pre-wrap { display: none; }
    .skills-mobile   { display: block; }
  }

  @media (max-width: 540px) {
    .container { padding: 28px 16px 48px; }
    .header-inner { flex-direction: column; gap: 16px; align-items: flex-start; }
    .header-photo { width: 80px; height: 110px; }
    .project { padding: 16px 16px; }
    .project-meta { flex-direction: column; gap: 2px; }
    .testimonials-row { flex-direction: column; }
    .skills-group { flex-direction: column; gap: 6px; }
    .skills-group-label { min-width: unset; }
    .education-item { flex-direction: column; gap: 2px; }
    .header-info h1 { font-size: 20px; }
    .footer-prompt { font-size: 11px; }
  }
  /* Print */
  @media print {
    :root {
      --bg: #fff;
      --surface: #f8f8f8;
      --border: #ddd;
      --text: #222;
      --text-dim: #666;
      --text-bright: #000;
      --link: #333;
      --available: #2a6a30;
      --badge-bg: #f5f5f5;
      --badge-border: #ddd;
    }

    .copy-email,
    .btn-cv,
    .footer-actions,
    .testimonials-more { display: none !important; }

    .status-dot { animation: none !important; }

    .container { padding: 12px 0; max-width: 100%; }

    .project, .testimonial { break-inside: avoid; }

    .testimonials-row { flex-direction: column; gap: 8px; }

    .header-photo { opacity: 1 !important; }

    a { color: #333 !important; text-decoration: none; }
  }
</style>
