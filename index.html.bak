<script>
  // ── Terminal: typing + output reveal ────────────────────────────
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const SPEED   = 28; // ms per character
    const STAGGER = 70; // ms between output lines

    // Pre-hide output content
    document.querySelectorAll('.about p, .about-list li').forEach(el => {
      el.style.opacity = '0';
      el.style.transition = 'opacity 0.2s ease';
    });

    const skillsPre = document.querySelector('.skills-pre');
    if (skillsPre) {
      const lines = skillsPre.innerHTML.trimEnd().split('\n');
      skillsPre.innerHTML = lines.map(l => `<span class="pre-line">${l}</span>`).join('');
      skillsPre.querySelectorAll('.pre-line').forEach(el => {
        el.style.opacity = '0';
        el.style.transition = 'opacity 0.15s ease';
      });
    }

    document.querySelectorAll('.footer-actions, .footer-links').forEach(el => {
      el.style.opacity = '0';
      el.style.transition = 'opacity 0.3s ease';
    });

    // Pre-clear prompt text to prevent flash-of-full-text on scroll
    document.querySelectorAll('.about-prompt, .skills-title, .footer-prompt').forEach(el => {
      const ps = el.querySelector('.ps');
      if (!ps) return;
      const sibling = ps.nextSibling;
      if (!sibling || sibling.nodeType !== Node.TEXT_NODE) return;
      el.dataset.cmd = sibling.textContent.replace(/^\s/, '');
      sibling.textContent = ' ';
    });

    // Typing function with onDone callback
    function runTyping(el, onDone, speed = SPEED) {
      const cmd = el.dataset.cmd;
      if (!cmd) return;

      const typed  = document.createElement('span');
      const cursor = document.createElement('span');
      cursor.className = 'type-cursor';
      el.appendChild(typed);
      el.appendChild(cursor);

      let i = 0;
      const tick = setInterval(() => {
        typed.textContent += cmd[i++];
        if (i >= cmd.length) {
          clearInterval(tick);
          setTimeout(() => {
            cursor.classList.add('type-cursor--done');
            if (onDone) onDone();
          }, 400);
        }
      }, speed);
    }

    // Output reveal per section
    function revealAbout() {
      [...document.querySelectorAll('.about p, .about-list li')]
        .forEach((el, i) => setTimeout(() => { el.style.opacity = '1'; }, i * STAGGER));
    }

    function revealSkills() {
      [...document.querySelectorAll('.skills-pre .pre-line')]
        .forEach((el, i) => setTimeout(() => { el.style.opacity = '1'; }, i * STAGGER));
    }

    function revealFooter() {
      [...document.querySelectorAll('.footer-actions, .footer-links')]
        .forEach((el, i) => setTimeout(() => { el.style.opacity = '1'; }, i * 200));
    }

    // Wire up observers
    [
      { selector: '.about-prompt',  onDone: revealAbout  },
      { selector: '.skills-title',  onDone: revealSkills },
      { selector: '.footer-prompt', onDone: revealFooter, speed: 12 },
    ].forEach(({ selector, onDone, speed }) => {
      const el = document.querySelector(selector);
      if (!el) return;
      const io = new IntersectionObserver(([entry]) => {
        if (!entry.isIntersecting) return;
        io.unobserve(el);
        runTyping(el, onDone, speed);
      }, { threshold: 0.8 });
      io.observe(el);
    });
  })();

  // Copy email
  document.querySelector('.copy-email').addEventListener('click', function () {
    navigator.clipboard.writeText('taranenko.denis.serg@gmail.com').then(() => {
      this.textContent = 'copied!';
      this.classList.add('copied');
      setTimeout(() => {
        this.textContent = 'copy';
        this.classList.remove('copied');
      }, 2000);
    });
  });
</script>
</body>
</html>
